APP_PORT=3000
NODE_ENV=production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_helper
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres:5432/agent_helper

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-files

# Qdrant
QDRANT_URL=http://qdrant:6333

# vLLM
LLM_URL=http://vllm-llm:8000/v1
LLM_MODEL=Qwen/Qwen3-14B

EMBED_URL=http://vllm-embed:8000/v1
EMBED_MODEL=intfloat/e5-small-v2

RERANK_URL=http://vllm-rerank:8000/v1
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

HF_TOKEN=hf_lllll